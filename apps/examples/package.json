{
  "name": "@aspect/examples",
  "version": "3.15.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "build:web": "npm run build",
    "dev": "serve . -l 8080 --no-clipboard",
    "dev:electron": "npm run build && electron electron/main.cjs",
    "build:desktop": "npm run build && electron-builder",
    "build:mobile": "npm run build && node scripts/cordova-sync.mjs",
    "run:android": "npm run build:mobile && cd cordova && npx cordova run android",
    "run:ios": "npm run build:mobile && cd cordova && npx cordova run ios"
  },
  "dependencies": {
    "@aspect/cocos2d": "*",
    "@aspect/extensions": "*",
    "@aspect/external": "*",
    "@aspect/socketio": "*",
    "@aspect/tilemap": "*"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "org.cocos2d.examples",
    "productName": "Cocos2d Examples",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "electron/**",
      "dist/**",
      "index.html",
      "style*.css",
      "res/**"
    ],
    "win":   { "target": "portable" },
    "mac":   { "target": "dmg" },
    "linux": { "target": "AppImage" }
  }
}
